# ─────────────────────────────────────────────
#  Social Analytics — Environment Variables
#  Copy this file to .env and fill your values
# ─────────────────────────────────────────────

# MongoDB (local or Atlas)
MONGO_URI=mongodb://localhost:sss27017
DB_NAME=social_analytics

# YouTube Data API v3 (console.cloud.google.com)
YOUTUBE_API_KEY=sssAIzaSyBcsssOOYs-1KKtD5sssRBpPFjFRsssUdaR1w-pe2o8sss

# Reddit API (reddit.com/prefs/apps → create app → script type)
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=SocialAnalyticsBot/1.0

# App
APP_ENV=development
APP_PORT=8000
